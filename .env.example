# Database connection (required: backend + stasis)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=callytics
DB_USER=callytics
DB_PASS=callytics
# Optional (tests only): admin DB name used by backend test setup fallback
DB_ADMIN_NAME=postgres
# Optional (tests/compose compatibility): fallback DB name alias used by test setup
POSTGRES_DB=callytics
# Optional (tests/compose compatibility): fallback DB password alias used by test setup
POSTGRES_PASSWORD=callytics

# Redis connection (required: backend + stasis)
REDIS_HOST=localhost
REDIS_PORT=6379

# Asterisk ARI (required)
ARI_URL=http://127.0.0.1:8088
ARI_USER=callytics
ARI_PASS=callytics
ARI_APP=callytics
# Optional alias: some backend checks read ARI_PASSWORD explicitly
ARI_PASSWORD=callytics

# Asterisk AMI (required)
AMI_HOST=127.0.0.1
AMI_PORT=5038
AMI_USER=callytics
AMI_PASS=callytics
# Optional alias: backend services also accept AMI_PASSWORD
AMI_PASSWORD=callytics

# Backend runtime (required)
BACKEND_PORT=3001
NODE_ENV=development
# Optional: absolute backend base URL used by stasis HTTP callbacks/fetches
BACKEND_URL=http://127.0.0.1:3001
# Optional: stasis health server port (compose defaults to 3002)
STASIS_HEALTH_PORT=3002

# Internal auth token between stasis and backend recording APIs (required for runtime integration)
RECORDINGS_INTERNAL_TOKEN=change-me-in-production

# Host/public addressing and SIP relay tuning
# Required in non-local deployments: used for SIP registration QR/provisioning URLs and VPN fallback IP.
HOST_IP=127.0.0.1
# Optional: LAN CIDR override injected into generated pjsip relay transport local_net.
LOCAL_NET=192.168.1.0/24
# Required for SIP listener: Asterisk bind port (avoid conflict with host 5060 if needed).
SIP_PORT=5080
# Optional: fixed public IP override for VPN relay templating and external address resolution.
VPN_PUBLIC_IP=
# Optional: 64-char hex key for VPN relay private-key encryption at rest. If unset/invalid, key is derived from HOST_IP.
ENCRYPTION_KEY=

# Optional filesystem overrides (useful in tests/custom deploy layouts)
# Optional: Asterisk config directory path used by backend config writers.
ASTERISK_CONFIG_DIR=/etc/asterisk
# Optional: WireGuard config directory used by backend VPN service.
WIREGUARD_CONFIG_DIR=../wireguard-config
# Optional: backup output directory used by backend backup service.
BACKUP_DIR=/app/backups
# Optional: recordings root used by backend backup/restore service.
RECORDINGS_DIR=/var/lib/asterisk/recording
# Optional: audio storage root used by backend backup/restore service.
AUDIO_STORAGE_DIR=/app/storage/audio
# Optional: GeoIP DB directory used by firewall diagnostics/jobs.
GEOIP_DIR=/app/geoip

# Optional callback/queue MOH behavior (stasis)
# Optional: MOH class for direct outbound callbacks.
CALLBACK_MOH_CLASS=callytics-hold
# Optional: MOH class for queue login / queue waiting / conference hold flows.
QUEUE_LOGIN_MOH_CLASS=callytics-hold
# Optional: MOH class for direct outbound dialing flows.
DIRECT_OUTBOUND_MOH_CLASS=callytics-hold
# Optional: default ISO country code for callback destination normalization.
CALLBACK_DEFAULT_COUNTRY=US

# Optional capture sidecar flags (asterisk docker capture-sidecar.js)
TSHARK_ENABLED=true
TSHARK_PORT=5080

# Optional firewall GeoIP download key (required only when enabling MaxMind auto-download/update)
MAXMIND_LICENSE_KEY=

# Frontend build/runtime env (optional)
# Optional: backend base URL for frontend API/socket calls (defaults to http://localhost:3001).
VITE_API_BASE_URL=http://localhost:3001
# Optional: frontend version label shown in UI (Vite injects from package version by default).
VITE_APP_VERSION=dev
# Optional: Vite test-mode flag used by config when running Vitest.
VITEST=

# Optional backend test harness override (tests only)
TEST_DATABASE_URL=

# Optional WireGuard container identity/timezone (docker-compose wireguard profile)
PUID=1000
PGID=1000
TZ=UTC
# Optional: public hostname/IP wireguard container advertises (compose default: auto).
WIREGUARD_SERVERURL=auto
