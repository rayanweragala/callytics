# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=callytics
DB_USER=callytics
DB_PASS=callytics

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Asterisk ARI
ARI_URL=http://127.0.0.1:8088
ARI_USER=callytics
ARI_PASS=callytics
ARI_APP=callytics

# Asterisk AMI
AMI_HOST=127.0.0.1
AMI_PORT=5038
AMI_USER=callytics
AMI_PASS=callytics

# Backend HTTP port
BACKEND_PORT=3001
NODE_ENV=development

# Internal token for recording persistence between Stasis and backend
RECORDINGS_INTERNAL_TOKEN=change-me-in-production

# Host machine IP — used for SIP registration QR codes and provisioning URLs
HOST_IP=127.0.0.1

# SIP port Asterisk listens on (must not be 5060 if host machine uses 5060)
SIP_PORT=5080
