{
  "name": "@callytics/backend",
  "version": "0.1.0",
  "description": "Callytics NestJS backend",
  "private": true,
  "license": "MIT",
  "main": "dist/main.js",
  "scripts": {
    "test": "jest",
    "test:fast": "jest --selectProjects unit --passWithNoTests",
    "test:unit": "jest --selectProjects unit --passWithNoTests",
    "test:int": "jest --selectProjects integration --runInBand",
    "test:cov": "jest --coverage",
    "test:ci": "jest --ci --coverage --runInBand",
    "test:full": "jest --ci --coverage --runInBand --detectOpenHandles",
    "migration:run": "ts-node src/db/run-migrations.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@maxmind/geoip2-node": "^6.3.4",
    "@nestjs/common": "^10.4.2",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.2",
    "@nestjs/platform-express": "^10.4.2",
    "@nestjs/platform-socket.io": "^10.4.2",
    "@nestjs/schedule": "^4.1.1",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/websockets": "^10.4.2",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "libphonenumber-js": "^1.12.42",
    "multer": "^1.4.5-lts.1",
    "pcap-writer": "^1.0.1",
    "pg": "^8.12.0",
    "qrcode": "^1.5.4",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.5",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.2",
    "@nestjs/schematics": "^10.1.4",
    "@nestjs/testing": "^10.4.2",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.5.4",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
